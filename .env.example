# ---- LLM provider (used by the LangGraph agent) ----
# openai | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Used when LLM_PROVIDER=ollama (also used by MemoryPalace for embeddings)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3:1.7b

# ---- MemoryPalace (Postgres + pgvector) ----
# Inside docker compose, hostname is `postgres`
MEMORY_PALACE_DATABASE_URL=postgresql://construction:construction@postgres:5432/memory_palace
MEMORY_PALACE_EMBEDDING_MODEL=nomic-embed-text
MEMORY_PALACE_LLM_MODEL=qwen3:1.7b
MEMORY_PALACE_INSTANCE_ID=construction-analyzer

# ---- LangGraph thread checkpointer (SQLite, persistent across restarts) ----
CHECKPOINT_DB_PATH=/app/data/checkpoints.sqlite

# ---- Document ingestion ----
DOCUMENTS_DIR=/app/data/documents
REGISTRY_DB_PATH=/app/data/registry.sqlite
MAX_UPLOAD_BYTES=25000000

# ---- CAD/export conversion (optional; blank command template disables it) ----
ENGINEERING_CONVERTER_COMMAND_TEMPLATE=
ENGINEERING_CONVERTER_TIMEOUT_SECONDS=30
ENGINEERING_CONVERTER_OUTPUT_DIR=/app/data/conversions
ENGINEERING_CONVERTER_OUTPUT_EXTENSION=.pdf
ENGINEERING_CONVERTER_SMOKE_INPUT_PATH=

# ---- Frontend ----
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ---- Host port mappings (override if you have other services on these ports) ----
# The internal compose network always uses the standard ports; these only
# control what the host sees.
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000
POSTGRES_HOST_PORT=5433
OLLAMA_HOST_PORT=11434

# ---- Knowledge base backend: memorypalace (default) | fake (no Ollama/Postgres needed) ----
KB_BACKEND=memorypalace
